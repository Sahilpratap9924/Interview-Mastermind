{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    },
    {
      "src": "api/index.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {      "src": "^/_serverFn/(.*)",
      "dest": "/api/index.mjs"
    },
    {      "src": "/(.*)",
      "dest": "/api/index.mjs"
    }
  ]
}

